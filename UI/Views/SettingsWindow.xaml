<Window x:Class="SnipShottyBoard.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="⚙️ SnipShottyBoard Settings"
        Height="550" Width="700"
        MinHeight="500" MinWidth="650"
        ResizeMode="CanResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner">

    <!-- 🎨 Window Resources -->
    <Window.Resources>
        <!-- 🗂️ Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="40" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource HoverTransparentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 🎯 Modern Window Chrome for consistency -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" 
                      ResizeBorderThickness="8" 
                      UseAeroCaptionButtons="False"
                      NonClientFrameEdges="None"
                      GlassFrameThickness="0"
                      CornerRadius="12" />
    </WindowChrome.WindowChrome>

    <!-- 🏗️ Modern Container with Drop Shadow -->
    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" Opacity="0.6" BlurRadius="12"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <!-- 📊 Custom Header Bar -->
                <RowDefinition Height="32" />
                <!-- 📝 Settings Content -->
                <RowDefinition Height="*" />
                <!-- 🔘 Action Buttons -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 🎯 Modern Header Bar with Rounded Top Corners -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    CornerRadius="12,12,0,0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- Icon -->
                    <ColumnDefinition Width="*" />     <!-- Title -->
                    <ColumnDefinition Width="Auto" />  <!-- Close button -->
                </Grid.ColumnDefinitions>

                <!-- ⚙️ Settings Icon -->
                <TextBlock Grid.Column="0" 
                           Text="⚙️"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="8,0,4,0"
                           Foreground="{DynamicResource AppForegroundBrush}" />

                <!-- 📍 Title -->
                <TextBlock Grid.Column="1" 
                           Text="Settings"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppForegroundBrush}" />

                <!-- ❌ Close Button -->
                <Button Grid.Column="2" 
                        Content="×"
                        Style="{DynamicResource HeaderButtonStyle}"
                        Click="Close_Click"
                        ToolTip="Close"
                        FontSize="16"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                </Grid>
            </Border>

            <!-- 📝 Main Settings Content Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- 📋 Left Sidebar for Tabs -->
                    <ColumnDefinition Width="180" />
                    <!-- 📄 Content Area -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 🗂️ Left Sidebar with Tab Buttons -->
                <Border Grid.Column="0"
                        Background="{DynamicResource HeaderBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    
                    <StackPanel Margin="0,16,0,16">
                        
                        <!-- 🏠 General Tab -->
                        <Button x:Name="GeneralTabButton"
                                Content="🏠 General"
                                Click="TabButton_Click"
                                Tag="General"
                                Style="{StaticResource TabButtonStyle}" />

                        <!-- 🎨 Appearance Tab -->
                        <Button x:Name="AppearanceTabButton"
                                Content="🎨 Appearance"
                                Click="TabButton_Click"
                                Tag="Appearance"
                                Style="{StaticResource TabButtonStyle}" />

                        <!-- 💻 Window Tab -->
                        <Button x:Name="WindowTabButton"
                                Content="💻 Window"
                                Click="TabButton_Click"
                                Tag="Window"
                                Style="{StaticResource TabButtonStyle}" />

                        <!-- 📋 Tab Settings Tab -->
                        <Button x:Name="TabSettingsTabButton"
                                Content="📋 Tab Settings"
                                Click="TabButton_Click"
                                Tag="TabSettings"
                                Style="{StaticResource TabButtonStyle}" />

                    </StackPanel>
                </Border>

                <!-- 📄 Content Area -->
                <ScrollViewer Grid.Column="1" 
                              VerticalScrollBarVisibility="Auto"
                              Padding="24">
                    
                    <!-- 🗂️ Main Content Container -->
                    <Grid>
                        <!-- 🏠 General Settings Panel -->
                        <StackPanel x:Name="GeneralPanel" 
                                    Visibility="Visible">
                        
                        <TextBlock Text="🏠 General Settings"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppForegroundBrush}"
                                   Margin="0,0,0,20" />

                        <!-- 💾 Auto-Save Settings -->
                        <GroupBox Header="💾 Auto-Save Settings" 
                                  Padding="16"
                                  Background="{DynamicResource TabBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  Margin="0,0,0,16">
                            
                            <StackPanel>
                                <!-- Enable Auto-Save -->
                                <CheckBox x:Name="AutoSaveEnabledCheckBox"
                                          Content="Enable auto-save"
                                          Foreground="{DynamicResource AppForegroundBrush}"
                                          Checked="AutoSaveEnabled_Changed"
                                          Unchecked="AutoSaveEnabled_Changed"
                                          Margin="0,0,0,12" />
                                
                                <!-- Save Interval -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Save every:"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource AppForegroundBrush}"
                                               Margin="0,0,12,0" />
                                    
                                    <ComboBox x:Name="SaveIntervalComboBox"
                                              Width="100"
                                              SelectionChanged="SaveInterval_Changed">
                                        <ComboBoxItem Content="3 sec" Tag="3" />
                                        <ComboBoxItem Content="5 sec" Tag="5" />
                                        <ComboBoxItem Content="10 sec" Tag="10" />
                                        <ComboBoxItem Content="30 sec" Tag="30" />
                                        <ComboBoxItem Content="1 min" Tag="60" />
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        </StackPanel>

                        <!-- 🎨 Appearance Settings Panel -->
                        <StackPanel x:Name="AppearancePanel" 
                                    Visibility="Collapsed">
                        
                        <TextBlock Text="🎨 Appearance Settings"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppForegroundBrush}"
                                   Margin="0,0,0,20" />

                        <!-- Theme Settings -->
                        <GroupBox Header="🌙 Theme" 
                                  Padding="16"
                                  Background="{DynamicResource TabBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  Margin="0,0,0,16">
                            
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Theme:"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppForegroundBrush}"
                                           Margin="0,0,12,0" />
                                
                                <ComboBox x:Name="ThemeComboBox"
                                          Width="140"
                                          SelectionChanged="Theme_Changed">
                                    <ComboBoxItem Content="🌙 Dark" Tag="Dark" />
                                    <ComboBoxItem Content="☀️ Light" Tag="Light" />
                                </ComboBox>
                            </StackPanel>
                        </GroupBox>

                        <!-- Font Settings -->
                        <GroupBox Header="🔤 Font" 
                                  Padding="16"
                                  Background="{DynamicResource TabBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Font size:"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppForegroundBrush}"
                                           Margin="0,0,12,0" />
                                
                                <ComboBox x:Name="FontSizeComboBox"
                                          Width="120"
                                          SelectionChanged="FontSize_Changed">
                                    <ComboBoxItem Content="Small" Tag="12" />
                                    <ComboBoxItem Content="Medium" Tag="14" />
                                    <ComboBoxItem Content="Large" Tag="16" />
                                    <ComboBoxItem Content="Extra Large" Tag="18" />
                                </ComboBox>
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>

                    <!-- 💻 Window Settings Panel -->
                    <StackPanel x:Name="WindowPanel" 
                                Visibility="Collapsed">
                        
                        <TextBlock Text="💻 Window Settings"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppForegroundBrush}"
                                   Margin="0,0,0,20" />

                        <!-- Window Behavior -->
                        <GroupBox Header="🪟 Window Behavior" 
                                  Padding="16"
                                  Background="{DynamicResource TabBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  Margin="0,0,0,16">
                            
                            <StackPanel>
                                <!-- Always on Top -->
                                <CheckBox x:Name="AlwaysOnTopCheckBox"
                                          Content="Keep window always on top"
                                          Foreground="{DynamicResource AppForegroundBrush}"
                                          Checked="AlwaysOnTop_Changed"
                                          Unchecked="AlwaysOnTop_Changed"
                                          Margin="0,0,0,12" />
                                
                                <!-- Remember Window Position -->
                                <CheckBox x:Name="RememberWindowPositionCheckBox"
                                          Content="Remember window position and size"
                                          Foreground="{DynamicResource AppForegroundBrush}"
                                          IsChecked="True"
                                          IsEnabled="False"
                                          ToolTip="Always enabled" />
                            </StackPanel>
                        </GroupBox>

                        <!-- Startup Settings -->
                        <GroupBox Header="🚀 Startup" 
                                  Padding="16"
                                  Background="{DynamicResource TabBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            
                            <StackPanel>
                                <!-- Start with Windows -->
                                <CheckBox x:Name="StartWithWindowsCheckBox"
                                          Content="Start with Windows"
                                          Foreground="{DynamicResource AppForegroundBrush}"
                                          IsEnabled="False"
                                          ToolTip="Coming in future version" />
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>

                    <!-- 📋 Tab Settings Panel -->
                    <StackPanel x:Name="TabSettingsPanel" 
                                Visibility="Collapsed">
                        
                        <TextBlock Text="📋 Tab Settings"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppForegroundBrush}"
                                   Margin="0,0,0,20" />

                        <!-- Tab Limits -->
                        <GroupBox Header="🔢 Tab Limits" 
                                  Padding="16"
                                  Background="{DynamicResource TabBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  Margin="0,0,0,16">
                            
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Maximum tabs:"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppForegroundBrush}"
                                           Margin="0,0,12,0" />
                                
                                <ComboBox x:Name="MaxTabsComboBox"
                                          Width="100"
                                          SelectionChanged="MaxTabs_Changed">
                                    <ComboBoxItem Content="10" Tag="10" />
                                    <ComboBoxItem Content="20" Tag="20" />
                                    <ComboBoxItem Content="50" Tag="50" />
                                    <ComboBoxItem Content="Unlimited" Tag="0" />
                                </ComboBox>
                            </StackPanel>
                        </GroupBox>

                        <!-- Tab Behavior -->
                        <GroupBox Header="⚡ Tab Behavior" 
                                  Padding="16"
                                  Background="{DynamicResource TabBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            
                            <StackPanel>
                                <!-- Confirm Tab Deletion -->
                                <CheckBox x:Name="ConfirmTabDeletionCheckBox"
                                          Content="Confirm before deleting tabs"
                                          Foreground="{DynamicResource AppForegroundBrush}"
                                          IsChecked="True"
                                          Checked="ConfirmTabDeletion_Changed"
                                          Unchecked="ConfirmTabDeletion_Changed" />
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>

                    </Grid>

                </ScrollViewer>

            </Grid>

            <!-- 🔘 Action Buttons -->
            <Border Grid.Row="2" 
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right">
                    
                    <!-- 🔄 Reset Button -->
                    <Button Content="🔄 Reset to Defaults"
                            Click="Reset_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0" />
                    
                    <!-- ❌ Cancel Button -->
                    <Button Content="❌ Cancel"
                            Click="Cancel_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0" />
                    
                    <!-- ✅ Apply Button -->
                    <Button Content="✅ Apply"
                            Click="Apply_Click"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window> 