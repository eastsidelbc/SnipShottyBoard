<ui:FluentWindow x:Class="SnipShottyBoard.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SnipShottyBoard"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Height="500" Width="400" MinHeight="300" MinWidth="250"
        ResizeMode="CanResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        WindowCornerPreference="Round"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- 🎯 FluentWindow Native Title Bar (auto-height) -->
            <RowDefinition Height="Auto" />
            <!-- 📑 Tab Strip -->
            <RowDefinition Height="Auto" />
            <!-- 📝 Main Content -->
            <RowDefinition Height="*" />
            <!-- 📊 Status Bar -->
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!-- 🎯 FluentWindow Native Title Bar — merged action buttons + pin + system caption -->
        <ui:TitleBar x:Name="MainTitleBar"
                     Grid.Row="0"
                     Title="SnipShottyBoard"
                     Background="{DynamicResource AppBackgroundBrush}"
                     Padding="0">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="4,0,0,0" VerticalAlignment="Top">
                    <!-- New Note — leftmost, near window corner -->
                    <Button Style="{DynamicResource TitleBarButtonStyle}"
                            Click="NewTab_Click"
                            ToolTip="New note (Ctrl+N)">
                        <materialDesign:PackIcon Kind="PlusBoxOutline" Width="16" Height="16" />
                    </Button>

                    <!-- Manage Note Windows -->
                    <Button Style="{DynamicResource TitleBarButtonStyle}"
                            Click="NoteWindows_Click"
                            ToolTip="Manage note windows">
                        <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16" />
                    </Button>

                    <!-- Delete Current Tab -->
                    <Button Style="{DynamicResource TitleBarButtonStyle}"
                            Click="DeleteTab_Click"
                            ToolTip="Delete current tab">
                        <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16" />
                    </Button>

                    <!-- Settings -->
                    <Button Style="{DynamicResource TitleBarButtonStyle}"
                            Click="Settings_Click"
                            ToolTip="Settings (Ctrl+,)">
                        <materialDesign:PackIcon Kind="CogOutline" Width="16" Height="16" />
                    </Button>

                    <!-- Help -->
                    <Button Style="{DynamicResource TitleBarButtonStyle}"
                            Click="Help_Click"
                            ToolTip="Features and shortcuts">
                        <materialDesign:PackIcon Kind="HelpCircleOutline" Width="16" Height="16" />
                    </Button>

                    <!-- Developer Tools -->
                    <Button Style="{DynamicResource TitleBarButtonStyle}"
                            Click="Developer_Click"
                            ToolTip="Developer tools (logs, diagnostics)">
                        <materialDesign:PackIcon Kind="WrenchOutline" Width="16" Height="16" />
                    </Button>
                </StackPanel>
            </ui:TitleBar.Header>

            <ui:TitleBar.TrailingContent>
                <Button x:Name="PinButton"
                        Style="{DynamicResource TitleBarPinButtonStyle}"
                        Click="Pin_Click"
                        ToolTip="Always on top: Off">
                    <materialDesign:PackIcon Kind="PinOutline" Width="16" Height="16" />
                </Button>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <!-- 📑 Tab Strip — flat chrome, tabs float via contrast -->
        <Border Grid.Row="1"
                Background="{DynamicResource AppBackgroundBrush}"
                BorderBrush="{DynamicResource SubtleDividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,4,4,2">

            <ScrollViewer Background="Transparent"
                          MaxHeight="200"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <!-- 🏷️ Custom Tab Header Panel with Multi-Row Wrapping -->
                <WrapPanel x:Name="TabHeaderPanel"
                           Orientation="Horizontal"
                           Margin="4,2"
                           Background="Transparent" />
            </ScrollViewer>
        </Border>

        <!-- 📝 Main Content Area — solid zinc card with depth shadow -->
        <Border Grid.Row="2"
                Background="{DynamicResource ContentCardBrush}"
                CornerRadius="6"
                Margin="4,0,4,2"
                BorderBrush="{DynamicResource SubtleDividerBrush}"
                BorderThickness="1,1,1,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Direction="270"
                                  ShadowDepth="2"
                                  Opacity="0.2"
                                  BlurRadius="6"/>
            </Border.Effect>

            <!-- 🔗 Tab Content Display -->
            <ContentPresenter x:Name="TabContentArea"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch" />
        </Border>

        <!-- 📊 Modern Status Bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- Tab count -->
                    <ColumnDefinition Width="*" />     <!-- Spacer -->
                    <ColumnDefinition Width="Auto" />  <!-- Word count -->
                    <ColumnDefinition Width="Auto" />  <!-- Save status -->
                    <ColumnDefinition Width="Auto" />  <!-- Current time -->
                </Grid.ColumnDefinitions>

                <!-- 📑 Tab count -->
                <TextBlock x:Name="TabCountStatus"
                           Grid.Column="0"
                           Text="1 tab"
                           FontSize="11"
                           Foreground="{DynamicResource AppForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />

                <!-- 📝 Word count -->
                <TextBlock x:Name="WordCountStatus"
                           Grid.Column="2"
                           Text="0 words"
                           FontSize="11"
                           Foreground="{DynamicResource AppForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <!-- 💾 Save status -->
                <TextBlock x:Name="SaveStatus"
                           Grid.Column="3"
                           Text="Saved"
                           FontSize="11"
                           Foreground="#4CAF50"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <!-- 🕒 Current time -->
                <TextBlock x:Name="TimeStatus"
                           Grid.Column="4"
                           Text="12:00 PM"
                           FontSize="11"
                           Foreground="{DynamicResource AppForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
