<Window x:Class="SnipShottyBoard.UI.NoteListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📝 Note Windows"
        Width="400"
        Height="500"
        MinWidth="350"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <!-- 🎨 Main window with modern styling -->
    <Border Background="{DynamicResource AppBackgroundBrush}" 
            CornerRadius="12"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                              Opacity="0.2" 
                              ShadowDepth="4" 
                              BlurRadius="12"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 📋 Title Bar -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    CornerRadius="12,12,0,0"
                    MouseDown="TitleBar_MouseDown">
                <Grid Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 📝 Window Title -->
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Margin="16,0">
                        <TextBlock Text="📝" 
                                   FontSize="16" 
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppForegroundBrush}"/>
                        <TextBlock Text="Note Windows" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppForegroundBrush}"/>
                    </StackPanel>

                    <!-- ✕ Close Button -->
                    <Button Grid.Column="1" 
                            x:Name="CloseButton"
                            Content="✕"
                            Width="32"
                            Height="24"
                            Margin="0,0,8,0"
                            Click="CloseButton_Click"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 📋 Note Windows List -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          Margin="8">
                <StackPanel x:Name="NoteWindowsList"/>
            </ScrollViewer>

            <!-- 🔧 Action Buttons -->
            <Border Grid.Row="2" 
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    CornerRadius="0,0,12,12"
                    Padding="12"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 📊 Status Info -->
                    <TextBlock x:Name="StatusText"
                               Grid.Column="0"
                               Text="No active note windows"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppForegroundBrush}"
                               Opacity="0.7"/>

                    <!-- ➕ New Note Window Button -->
                    <Button x:Name="NewWindowButton"
                            Grid.Column="1"
                            Content="➕ New Window"
                            Click="NewWindowButton_Click"
                            Margin="8,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window> 