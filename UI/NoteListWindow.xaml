<ui:FluentWindow x:Class="SnipShottyBoard.UI.NoteListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="📝 Note Windows"
        Width="400"
        Height="500"
        MinWidth="350"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None">

    <!-- 📝 Main Content -->
    <Grid>
        <Grid.RowDefinitions>
            <!-- 🎯 Title Bar -->
            <RowDefinition Height="Auto" />
            <!-- 📋 Note Windows List -->
            <RowDefinition Height="*"/>
            <!-- 🔧 Action Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 🎯 Title Bar with drag support and system buttons -->
        <ui:TitleBar Grid.Row="0"
                     Title="📝 Note Windows"
                     Icon="{x:Null}" />

        <!-- 📋 Note Windows List -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Margin="8">
            <StackPanel x:Name="NoteWindowsList"/>
        </ScrollViewer>

        <!-- 🔧 Action Buttons -->
        <Border Grid.Row="2" 
                Background="{DynamicResource HeaderBackgroundBrush}"
                Padding="12"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 📊 Status Info -->
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Text="No active note windows"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppForegroundBrush}"
                           Opacity="0.7"/>

                <!-- ➕ New Note Window Button -->
                <Button x:Name="NewWindowButton"
                        Grid.Column="1"
                        Content="➕ New Window"
                        Click="NewWindowButton_Click"
                        Margin="8,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
