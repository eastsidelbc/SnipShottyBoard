<Window x:Class="SnipShottyBoard.UI.CustomInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="280" Width="450"
        MinHeight="260" MinWidth="400"
        MaxHeight="350" MaxWidth="650"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False">

    <!-- 🎨 Custom Input Dialog Container with rounded corners and shadow -->
    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="8">
        
        <!-- ✨ Drop shadow effect -->
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                              Opacity="0.3" 
                              BlurRadius="10" 
                              ShadowDepth="3" 
                              Direction="270" />
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <!-- 📊 Header with icon and title -->
                <RowDefinition Height="Auto" />
                <!-- 📝 Content area with message and input -->
                <RowDefinition Height="*" />
                <!-- 🔘 Action buttons -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 📊 Header Section -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    CornerRadius="12,12,0,0"
                    Padding="16,12">
                
                <StackPanel Orientation="Horizontal">
                    <!-- 🎯 Dialog Icon -->
                    <TextBlock x:Name="DialogIcon" 
                               Text="✏️"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppForegroundBrush}"
                               Margin="0,0,12,0" />

                    <!-- 📍 Dialog Title -->
                    <TextBlock x:Name="DialogTitle" 
                               Text="Input Required"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppForegroundBrush}" />
                </StackPanel>
            </Border>

            <!-- 📝 Message Content and Input -->
            <Grid Grid.Row="1" 
                  Margin="20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <!-- 📄 Prompt Message -->
                <TextBlock x:Name="DialogMessage" 
                           Grid.Row="0"
                           Text="Please enter your input:"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AppForegroundBrush}"
                           Margin="0,0,0,12" />
                
                <!-- 📝 Input TextBox -->
                <TextBox x:Name="InputTextBox"
                         Grid.Row="1"
                         FontSize="14"
                         Padding="8"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Background="{DynamicResource TabBackgroundBrush}"
                         Foreground="{DynamicResource AppForegroundBrush}"
                         CaretBrush="{DynamicResource AppForegroundBrush}"
                         SelectionBrush="{DynamicResource BorderBrush}"
                         Margin="0,0,0,8">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Focusable="False"
                                                          HorizontalScrollBarVisibility="Hidden"
                                                          VerticalScrollBarVisibility="Hidden" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource AppForegroundBrush}" />
                                                <Setter Property="BorderThickness" Value="2" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>

            <!-- 🔘 Action Buttons -->
            <Border Grid.Row="2" 
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="20,16">
                
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right">
                    
                    <!-- ❌ Cancel Button -->
                    <Button x:Name="CancelButton"
                            Content="❌ Cancel"
                            Margin="0,0,12,0"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Click="Cancel_Click"
                            IsCancel="True" />
                    
                    <!-- ✅ OK Button -->
                    <Button x:Name="OkButton"
                            Content="✅ OK"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Click="Ok_Click"
                            IsDefault="True" />
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window> 