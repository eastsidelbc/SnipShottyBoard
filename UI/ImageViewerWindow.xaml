<Window x:Class="SnipShottyBoard.UI.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="🖼️ Image Viewer"
        MinWidth="400"
        MinHeight="300"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">

    <!-- 🔧 WindowChrome for proper resizing -->
    <WindowChrome.WindowChrome>
        <WindowChrome
            ResizeBorderThickness="8"
            CaptionHeight="35"
            CornerRadius="8"
            GlassFrameThickness="0">
        </WindowChrome>
    </WindowChrome.WindowChrome>

    <!-- 🎨 Custom window with beautiful themed chrome -->
    <Border Background="{DynamicResource AppBackgroundBrush}" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="3" Opacity="0.5" BlurRadius="10"/>
        </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <!-- 🏷️ Custom title bar -->
                    <RowDefinition Height="35"/>
                    <!-- 🛠️ Toolbar -->
                    <RowDefinition Height="55"/>
                    <!-- 🖼️ Image content -->
                    <RowDefinition Height="*"/>
                    <!-- 📊 Status bar -->
                    <RowDefinition Height="25"/>
                </Grid.RowDefinitions>
                
                <!-- 🏷️ Beautiful Custom Title Bar -->
                <Border Grid.Row="0" 
                        Background="{DynamicResource HeaderBackgroundBrush}" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="0,0,0,1"
                        CornerRadius="8,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 🖼️ Empty draggable title area -->
                        <Border Grid.Column="0"
                                Background="Transparent"
                                MouseDown="TitleBar_MouseDown"/>
                        
                        <!-- ✕ Themed Close Button -->
                        <Button Grid.Column="1"
                                Name="CloseButton"
                                Content="✕"
                                Width="35"
                                Height="25"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="11"
                                FontWeight="Bold"
                                Click="CloseButton_Click"
                                VerticalAlignment="Center"
                                Margin="0,5,8,5"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FFFF4444"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- 🛠️ Dark Modern Toolbar -->
                <Border Grid.Row="1"
                        Background="#FF2B2D31"
                        BorderBrush="#FF3A3D42"
                        BorderThickness="0,0,0,1">
                    
                    <StackPanel Orientation="Horizontal"
                                Margin="12,12"
                                VerticalAlignment="Center">
                        
                        <!-- 📋 Copy button -->
                        <Button x:Name="CopyButton"
                                Content="📋 Copy"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Click="CopyButton_Click"
                                ToolTip="Copy image to clipboard"
                                FontWeight="Medium"
                                WindowChrome.IsHitTestVisibleInChrome="True" />

                        <!-- 🗑️ Delete button -->
                        <Button x:Name="DeleteButton"
                                Content="🗑️ Delete"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Style="{StaticResource DangerButtonStyle}"
                                Click="DeleteButton_Click"
                                ToolTip="Delete this image"
                                FontWeight="Medium"
                                WindowChrome.IsHitTestVisibleInChrome="True" />

                        <!-- 🔄 Future toolbar buttons will go here -->
                    </StackPanel>
                </Border>

                <!-- 🖼️ Image display area -->
                <Border Grid.Row="2"
                        Background="#FF36393F"
                        Margin="0,0,0,0">
                    
                    <!-- 🖼️ Viewbox for automatic scaling when window is resized -->
                    <Viewbox Stretch="Uniform"
                             StretchDirection="Both"
                             Margin="10">
                        <!-- 🖼️ The actual image that scales with window -->
                        <Image x:Name="DisplayImage"
                               Stretch="None"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Viewbox>
                </Border>

                <!-- 📊 Dark Modern Status Bar -->
                <Border Grid.Row="3"
                        Background="#FF2B2D31"
                        BorderBrush="#FF3A3D42"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,8,8">
                    
                    <Grid Margin="8,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 📂 File name/path -->
                        <TextBlock Grid.Column="0"
                                   x:Name="StatusFileName"
                                   Text="No image loaded"
                                   FontSize="11"
                                   Foreground="#FFE3E5E8"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- 📏 Separator -->
                        <Rectangle Grid.Column="1"
                                   Width="1"
                                   Height="16"
                                   Fill="#FF4A4D52"
                                   Margin="8,0"
                                   VerticalAlignment="Center"/>

                        <!-- 📐 Image dimensions -->
                        <TextBlock Grid.Column="2"
                                   x:Name="StatusDimensions"
                                   Text="-- × -- px"
                                   FontSize="11"
                                   Foreground="#FFE3E5E8"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <!-- 💾 File size -->
                        <TextBlock Grid.Column="3"
                                   x:Name="StatusFileSize"
                                   Text="-- KB"
                                   FontSize="11"
                                   Foreground="#FFE3E5E8"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <!-- 📏 Separator -->
                        <Rectangle Grid.Column="4"
                                   Width="1"
                                   Height="16"
                                   Fill="#FF4A4D52"
                                   Margin="8,0"
                                   VerticalAlignment="Center"/>

                        <!-- 🕒 Date/time info -->
                        <TextBlock Grid.Column="5"
                                   x:Name="StatusDateTime"
                                   Text="--"
                                   FontSize="11"
                                   Foreground="#FFE3E5E8"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
    </Border>
</Window> 