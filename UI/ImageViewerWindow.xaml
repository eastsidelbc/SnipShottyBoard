<ui:FluentWindow x:Class="SnipShottyBoard.UI.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="🖼️ Image Viewer"
        MinWidth="400"
        MinHeight="300"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        ResizeMode="CanResize"
        WindowCornerPreference="Round"
        Background="{DynamicResource ContentCardBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <!-- 🛠️ Toolbar Row -->
        <ui:TitleBar Grid.Row="0" Title="">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                    <Button Content="📋 Copy"
                            Style="{DynamicResource TitleBarButtonStyle}"
                            Click="CopyButton_Click"
                            ToolTip="Copy image to clipboard"
                            Padding="6,2"
                            FontSize="13"
                            MinWidth="58"
                            Margin="0,0,4,0" />

                    <Button Content="🗑️ Delete"
                            Style="{DynamicResource TitleBarButtonStyle}"
                            Click="DeleteButton_Click"
                            ToolTip="Delete this image"
                            Padding="6,2"
                            FontSize="13"
                            MinWidth="58"
                            Margin="0,0,4,0" />

                    <Button x:Name="PrevButton" Content="◀ Prev"
                            Style="{DynamicResource TitleBarButtonStyle}"
                            Click="PrevButton_Click"
                            ToolTip="Previous image"
                            Padding="6,2"
                            FontSize="13"
                            MinWidth="65"
                            Margin="0,0,2,0"
                            Visibility="Collapsed" />

                    <Button x:Name="NextButton" Content="Next ▶"
                            Style="{DynamicResource TitleBarButtonStyle}"
                            Click="NextButton_Click"
                            ToolTip="Next image"
                            Padding="6,2"
                            FontSize="13"
                            MinWidth="65"
                            Margin="0,0,4,0"
                            Visibility="Collapsed" />

                    <Button Content="🔍 1:1"
                            Style="{DynamicResource TitleBarButtonStyle}"
                            Click="FitActualButton_Click"
                            ToolTip="Show actual pixel size"
                            Padding="6,2"
                            FontSize="13"
                            MinWidth="55" />
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- 🖼️ Image display area with Zoom & Pan -->
        <Border Grid.Row="1">
            <ScrollViewer x:Name="ImageScrollViewer"
                          Focusable="False"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden"
                          PanningMode="Both"
                          Padding="10"
                          PreviewMouseWheel="ImageScrollViewer_MouseWheel">
                <Grid x:Name="ImageContainer" Background="Transparent">
                    <Image x:Name="DisplayImage"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           MouseLeftButtonDown="DisplayImage_MouseLeftButtonDown"
                           MouseLeftButtonUp="DisplayImage_MouseLeftButtonUp"
                           MouseMove="DisplayImage_MouseMove"
                           LostMouseCapture="DisplayImage_LostMouseCapture"/>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- 📊 Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="8,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="StatusFileName" Text="No image loaded" FontSize="11" Foreground="{DynamicResource AppForegroundBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <Rectangle Grid.Column="1" Width="1" Height="16" Fill="{DynamicResource BorderBrush}" Margin="8,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="StatusDimensions" Text="-- × -- px" FontSize="11" Foreground="{DynamicResource AppForegroundBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="3" x:Name="StatusFileSize" Text="-- KB" FontSize="11" Foreground="{DynamicResource AppForegroundBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Rectangle Grid.Column="4" Width="1" Height="16" Fill="{DynamicResource BorderBrush}" Margin="8,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="5" x:Name="StatusZoom" Text="Fit" FontSize="11" Foreground="{DynamicResource AppForegroundBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="6" x:Name="StatusDateTime" Text="--" FontSize="11" Foreground="{DynamicResource AppForegroundBrush}" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
