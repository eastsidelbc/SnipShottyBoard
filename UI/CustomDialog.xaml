<Window x:Class="SnipShottyBoard.UI.CustomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="200" Width="400"
        MinHeight="150" MinWidth="300"
        MaxHeight="300" MaxWidth="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False">

    <!-- 🎨 Custom Dialog Container with rounded corners and shadow -->
    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="8">
        
        <!-- ✨ Drop shadow effect -->
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                              Opacity="0.3" 
                              BlurRadius="10" 
                              ShadowDepth="3" 
                              Direction="270" />
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <!-- 📊 Header with icon and title -->
                <RowDefinition Height="Auto" />
                <!-- 📝 Content area with message -->
                <RowDefinition Height="*" />
                <!-- ✅ Checkbox area (optional) -->
                <RowDefinition Height="Auto" />
                <!-- 🔘 Action buttons -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 📊 Header Section -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    CornerRadius="12,12,0,0"
                    Padding="16,12">
                
                <StackPanel Orientation="Horizontal">
                    <!-- 🎯 Dialog Icon -->
                    <TextBlock x:Name="DialogIcon" 
                               Text="❓"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppForegroundBrush}"
                               Margin="0,0,12,0" />

                    <!-- 📍 Dialog Title -->
                    <TextBlock x:Name="DialogTitle" 
                               Text="Confirmation"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppForegroundBrush}" />
                </StackPanel>
            </Border>

            <!-- 📝 Message Content -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,16">
                
                <TextBlock x:Name="DialogMessage" 
                           Text="Are you sure you want to continue?"
                           FontSize="14"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           Foreground="{DynamicResource AppForegroundBrush}"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top" />
            </ScrollViewer>

            <!-- ✅ Optional Checkbox Section -->
            <Border x:Name="CheckboxSection" 
                    Grid.Row="2"
                    Background="{DynamicResource TabBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12"
                    Visibility="Collapsed">
                
                <CheckBox x:Name="DontAskAgainCheckBox"
                          Content="Don't ask me again"
                          Foreground="{DynamicResource AppForegroundBrush}"
                          FontSize="12" />
            </Border>

            <!-- 🔘 Action Buttons -->
            <Border Grid.Row="3" 
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="20,16">
                
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right">
                    
                    <!-- ❌ Cancel/No Button -->
                    <Button x:Name="CancelButton"
                            Content="❌ Cancel"
                            Margin="0,0,12,0"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Click="Cancel_Click"
                            IsCancel="True" />
                    
                    <!-- ✅ Confirm/Yes Button -->
                    <Button x:Name="ConfirmButton"
                            Content="✅ Yes"
                            Style="{DynamicResource DangerButtonStyle}"
                            Click="Confirm_Click"
                            IsDefault="True" />
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window> 