<UserControl x:Class="SnipShottyBoard.UI.TextSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">
    
    <!-- 📝 TEXT SECTION — purely transparent, no effects here -->
    <!-- ALL hover and focus effects live on the outer ContentCardHoverStyle border in NoteTab.xaml -->
    <Grid Background="Transparent"
          VerticalAlignment="Stretch"
          HorizontalAlignment="Stretch">
        <TextBlock x:Name="PlaceholderText"
                  Text="Take a note..."
                  Foreground="{DynamicResource AppForegroundBrush}"
                  Opacity="0.35"
                  FontStyle="Italic"
                  FontSize="{DynamicResource BodyFontSize}"
                  FontFamily="{DynamicResource AppFontFamily}"
                  Margin="4,4,0,0"
                  VerticalAlignment="Top"
                  IsHitTestVisible="False"
                  Visibility="Visible" />
        <RichTextBox x:Name="NoteRichTextBox"
                    Background="Transparent"
                    Foreground="{DynamicResource AppForegroundBrush}"
                    CaretBrush="{DynamicResource AppForegroundBrush}"
                    BorderThickness="0"
                    AcceptsReturn="True"
                    UndoLimit="150"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalContentAlignment="Top"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    FontSize="{DynamicResource BodyFontSize}"
                    FontFamily="{DynamicResource AppFontFamily}"
                    Padding="4"
                    TextChanged="NoteRichTextBox_TextChanged"
                    PreviewMouseWheel="NoteRichTextBox_PreviewMouseWheel">
            <RichTextBox.Resources>
                <!-- 🎨 Readable line height -->
                <Style TargetType="Paragraph">
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="LineHeight" Value="22"/>
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>
    </Grid>
</UserControl> 