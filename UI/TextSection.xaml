<UserControl x:Class="SnipShottyBoard.UI.TextSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">
    
    <!-- 📝 TEXT SECTION - Self-contained with flexible height -->
    <Border Background="Transparent"
            BorderBrush="{DynamicResource AppForegroundBrush}"
            BorderThickness="0,0,0,0"
            CornerRadius="6,6,0,0"
            VerticalAlignment="Stretch"
            HorizontalAlignment="Stretch">
        <Grid Background="Transparent"
              VerticalAlignment="Stretch"
              HorizontalAlignment="Stretch">
            <TextBlock x:Name="PlaceholderText"
                      Text="Take a note..."
                      Foreground="{DynamicResource AppForegroundBrush}"
                      Opacity="0.5"
                      FontSize="14"
                      FontFamily="Segoe UI"
                      Margin="8"
                      VerticalAlignment="Top"
                      IsHitTestVisible="False"
                      Visibility="Visible" />
            <RichTextBox x:Name="NoteRichTextBox"
                        Background="Transparent"
                        Foreground="{DynamicResource AppForegroundBrush}"
                        CaretBrush="{DynamicResource AppForegroundBrush}"
                        BorderThickness="0"
                        AcceptsReturn="True"
                        UndoLimit="150"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        FontSize="14"
                        FontFamily="Segoe UI"
                        Padding="8"
                        ScrollViewer.CanContentScroll="True"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        TextChanged="NoteRichTextBox_TextChanged">
                <RichTextBox.Resources>
                    <!-- 🎨 Default paragraph style to match TextBox appearance -->
                    <Style TargetType="Paragraph">
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="LineHeight" Value="1.2"/>
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>
        </Grid>
    </Border>
</UserControl> 