<Window x:Class="SnipShottyBoard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SnipShottyBoard"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Height="500" Width="400" MinHeight="300" MinWidth="250"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">

    <!-- 🎯 Modern Window Chrome for Resizing + Custom Header -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" 
                      ResizeBorderThickness="8" 
                      UseAeroCaptionButtons="False"
                      NonClientFrameEdges="None"
                      GlassFrameThickness="0"
                      CornerRadius="12" />
    </WindowChrome.WindowChrome>

    <!-- 🏗️ Modern Container with Drop Shadow and Rounded Corners -->
    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" Opacity="0.6" BlurRadius="12"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <!-- 📊 Custom Header Bar -->
                <RowDefinition Height="32" />
                <!-- 📑 Tab Strip -->
                <RowDefinition Height="Auto" />
                <!-- 📝 Main Content -->
                <RowDefinition Height="*" />
                <!-- 📊 Status Bar -->
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <!-- 🎯 Modern Header Bar with Rounded Top Corners -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    CornerRadius="12,12,0,0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- + button -->
                    <ColumnDefinition Width="*" />     <!-- Draggable area -->
                    <ColumnDefinition Width="Auto" />  <!-- 📝 note windows button -->
                    <ColumnDefinition Width="Auto" />  <!-- ⚙️ settings button -->
                    <ColumnDefinition Width="Auto" />  <!-- 🗑️ delete button -->
                    <ColumnDefinition Width="Auto" />  <!-- Theme toggle -->
                    <ColumnDefinition Width="Auto" />  <!-- ℹ️ help button -->
                    <ColumnDefinition Width="Auto" />  <!-- × button -->
                </Grid.ColumnDefinitions>

                <!-- ➕ New Tab Button -->
                <Button Grid.Column="0" 
                        Content="+"
                        Style="{DynamicResource HeaderButtonStyle}"
                        Click="NewTab_Click"
                        ToolTip="New note"
                        WindowChrome.IsHitTestVisibleInChrome="True" />

                <!-- 📍 Draggable Title Area (WindowChrome handles this) -->
                <Grid Grid.Column="1" Background="Transparent" />

                <!-- 📝 Note Windows Button -->
                <Button Grid.Column="2" 
                        Content="📝"
                        Style="{DynamicResource HeaderButtonStyle}"
                        Click="NoteWindows_Click"
                        ToolTip="Manage note windows"
                        WindowChrome.IsHitTestVisibleInChrome="True" />

                <!-- ⚙️ Settings Button -->
                <Button Grid.Column="3" 
                        Content="⚙️"
                        Style="{DynamicResource HeaderButtonStyle}"
                        Click="Settings_Click"
                        ToolTip="Settings"
                        WindowChrome.IsHitTestVisibleInChrome="True" />

                <!-- 🗑️ Delete Tab Button -->
                <Button Grid.Column="4" 
                        Content="🗑️"
                        Style="{DynamicResource HeaderButtonStyle}"
                        Click="DeleteTab_Click"
                        ToolTip="Delete current tab"
                        WindowChrome.IsHitTestVisibleInChrome="True" />

                <!-- 🌙 Theme Toggle Button -->
                <Button Grid.Column="5" 
                        Content="🌙"
                        Style="{DynamicResource HeaderButtonStyle}"
                        Click="ToggleTheme_Click"
                        ToolTip="Toggle theme"
                        WindowChrome.IsHitTestVisibleInChrome="True" />

                <!-- ℹ️ Help Button -->
                <Button Grid.Column="6" 
                        Content="?"
                        Style="{DynamicResource HeaderButtonStyle}"
                        Click="Help_Click"
                        ToolTip="Features and shortcuts"
                        WindowChrome.IsHitTestVisibleInChrome="True" />

                <!-- ❌ Close Button -->
                <Button Grid.Column="7" 
                        Content="×"
                        Style="{DynamicResource HeaderButtonStyle}"
                        Click="Close_Click"
                        ToolTip="Close"
                        FontSize="16"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                </Grid>
            </Border>

            <!-- 📑 Tab Strip (Below Header) -->
            <ScrollViewer Grid.Row="1" 
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Hidden"
                          Background="{DynamicResource TabBackgroundBrush}">
                
                <!-- 🏷️ Custom Tab Header Panel (No Content Area) -->
                <StackPanel x:Name="TabHeaderPanel"
                           Orientation="Horizontal"
                           Margin="4,2"
                           Background="Transparent" />
            </ScrollViewer>

            <!-- 📝 Main Content Area (Tab Content) -->
            <Border Grid.Row="2" 
                    Background="{DynamicResource AppBackgroundBrush}">
                
                <!-- 🔗 Tab Content Display -->
                <ContentPresenter x:Name="TabContentArea"
                                  VerticalAlignment="Stretch"
                                  HorizontalAlignment="Stretch" />
            </Border>

            <!-- 📊 Modern Status Bar with Rounded Bottom Corners -->
            <Border Grid.Row="3" 
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12">
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />  <!-- Tab count -->
                        <ColumnDefinition Width="*" />     <!-- Spacer -->
                        <ColumnDefinition Width="Auto" />  <!-- Word count -->
                        <ColumnDefinition Width="Auto" />  <!-- Save status -->
                        <ColumnDefinition Width="Auto" />  <!-- Current time -->
                    </Grid.ColumnDefinitions>

                    <!-- 📑 Tab count -->
                    <TextBlock x:Name="TabCountStatus" 
                               Grid.Column="0"
                               Text="1 tab"
                               FontSize="11"
                               Foreground="{DynamicResource AppForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />

                    <!-- 📝 Word count -->
                    <TextBlock x:Name="WordCountStatus" 
                               Grid.Column="2"
                               Text="0 words"
                               FontSize="11"
                               Foreground="{DynamicResource AppForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />

                    <!-- 💾 Save status -->
                    <TextBlock x:Name="SaveStatus" 
                               Grid.Column="3"
                               Text="Saved"
                               FontSize="11"
                               Foreground="#4CAF50"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />

                    <!-- 🕒 Current time -->
                    <TextBlock x:Name="TimeStatus" 
                               Grid.Column="4"
                               Text="12:00 PM"
                               FontSize="11"
                               Foreground="{DynamicResource AppForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
