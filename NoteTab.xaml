<UserControl x:Class="SnipShottyBoard.NoteTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:SnipShottyBoard.UI"
             Background="{DynamicResource AppBackgroundBrush}">
    
    <!-- 📱 TWO RESIZABLE SECTIONS WITH INTERACTIVE SPLITTER -->
    <Grid Margin="12" Background="Transparent">
        <Grid.RowDefinitions>
            <!-- 📝 TEXT SECTION - Proportional (starts at 50%) -->
            <RowDefinition Height="*" x:Name="TextSectionRow"/>
            <!-- 🎛️ INTERACTIVE SPLITTER - Fixed but draggable -->
            <RowDefinition Height="Auto"/>
            <!-- 🖼️ MEDIA SECTION - Proportional (takes remaining) -->
            <RowDefinition Height="*" x:Name="MediaSectionRow"/>
        </Grid.RowDefinitions>

        <!-- 📝 TEXT SECTION - TOP HALF (resizable) -->
        <ui:TextSection x:Name="TextSectionControl" 
                       Grid.Row="0" />

        <!-- 🎛️ INTERACTIVE SPLITTER - Draggable divider -->
        <Border Grid.Row="1" 
                x:Name="SplitterBorder"
                Height="16"
                Background="Transparent"
                Margin="0,4"
                Cursor="SizeNS"
                MouseLeftButtonDown="Splitter_MouseLeftButtonDown"
                MouseMove="Splitter_MouseMove"
                MouseLeftButtonUp="Splitter_MouseLeftButtonUp"
                MouseLeave="Splitter_MouseLeave">
            
            <!-- 🎨 Visual splitter with hover effects -->
            <Grid>
                <!-- 📏 Main divider line -->
                <Rectangle Height="2"
                          Fill="{DynamicResource AppForegroundBrush}"
                          Opacity="0.2"
                          x:Name="SplitterLine"/>
                
                <!-- 🎯 Hover indicator (grip dots) -->
                <StackPanel Orientation="Horizontal"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           x:Name="SplitterGrip"
                           Opacity="0">
                    <Ellipse Width="4" Height="4" 
                            Fill="{DynamicResource AppForegroundBrush}" 
                            Opacity="0.4" Margin="1,0"/>
                    <Ellipse Width="4" Height="4" 
                            Fill="{DynamicResource AppForegroundBrush}" 
                            Opacity="0.4" Margin="1,0"/>
                    <Ellipse Width="4" Height="4" 
                            Fill="{DynamicResource AppForegroundBrush}" 
                            Opacity="0.4" Margin="1,0"/>
                    <Ellipse Width="4" Height="4" 
                            Fill="{DynamicResource AppForegroundBrush}" 
                            Opacity="0.4" Margin="1,0"/>
                    <Ellipse Width="4" Height="4" 
                            Fill="{DynamicResource AppForegroundBrush}" 
                            Opacity="0.4" Margin="1,0"/>
                </StackPanel>
            </Grid>

            <!-- 🎨 Hover effect triggers -->
            <Border.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="SplitterLine"
                                           Storyboard.TargetProperty="Opacity"
                                           To="0.5" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="SplitterGrip"
                                           Storyboard.TargetProperty="Opacity"
                                           To="0.8" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="SplitterLine"
                                           Storyboard.TargetProperty="Opacity"
                                           To="0.2" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="SplitterGrip"
                                           Storyboard.TargetProperty="Opacity"
                                           To="0" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>

        <!-- 🖼️ MEDIA SECTION - BOTTOM HALF (resizable) -->
        <ui:MediaSection x:Name="MediaSectionControl" 
                        Grid.Row="2" />
    </Grid>
</UserControl>
